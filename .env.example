# UEDU Environment Variables
# Copy this file to .env and fill in your keys

# Optional: Only needed for LLM feature extraction (models M7-M9)
# Get a key at https://aistudio.google.com/apikey
UEDU_GEMINI_API_KEY=

# Optional: Only needed for synthetic text generation experiments
UEDU_OPENAI_API_KEY=

# Random seed (default: 42)
UEDU_RANDOM_SEED=42
